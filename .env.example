# Copy this file to .env and fill in real values locally.
# NEVER commit the .env file itself — it is excluded via .gitignore.

# --- LLM Provider ---
ANTHROPIC_API_KEY=

# --- Optional: alternate/secondary model providers (if used) ---
OPENAI_API_KEY=

# --- Observability / Tracing (LangGraph / LangSmith) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=agentic-qa-poc

# --- Application ---
APP_ENV=development
LOG_LEVEL=info

# --- Test target under QA ---
TARGET_BASE_URL=https://example.com
